{
  "name": "zoom-wordle",
  "version": "1.0.2",
  "type": "module",
  "exports": "./server",
  "private": true,
  "scripts": {
    "prestart": "npm run build",
    "start": "node app.js",
    "dev": "node scripts/dev.js",
    "build": "vite build",
    "prepare": "npx husky install",
    "postprepare": "node scripts/gen-secrets.cjs"
  },
  "dependencies": {
    "@zoom/appssdk": "^0.16.39",
    "axios": "^1.18.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cookie-session": "^2.1.1",
    "debug": "^4.4.3",
    "express": "^4.22.2",
    "express-validator": "^6.15.0",
    "helmet": "^5.0.2",
    "http-errors": "^2.0.0",
    "morgan": "^1.11.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^7.1.0",
    "dotenv": "^16.0.0",
    "envsub": "^4.0.7",
    "eslint": "^8.9.0",
    "eslint-config-prettier": "^8.4.0",
    "eslint-plugin-react": "^7.37.5",
    "husky": "^7.0.4",
    "lint-staged": "^12.3.4",
    "nodemon": "^3.1.14",
    "prettier": "^2.5.1",
    "vite": "^8.1.3"
  },
  "nodemonConfig": {
    "quiet": true,
    "watch": [
      "server/**/*.js",
      "app.js",
      "config.js",
      ".env"
    ]
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --cache --fix",
      "prettier --write"
    ]
  }
}
