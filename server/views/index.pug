extends layout
include mixins/prompt-install

block content
    if isZoom
        h1.title Wordle
        p#status Preparing video overlay...
    else
        +prompt-install(title, installURL)
        p#status Open this app in Zoom to test the video overlay.

append scripts
    script(type="module" src=assetPath('/js/bundle.mjs'))
    script(nomodule src=assetPath('/js/bundle.js'))
